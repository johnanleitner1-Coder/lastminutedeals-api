# ============================================================
# .env.example — Copy this to .env and fill in your values.
# Never commit .env to git.
# ============================================================
# Priority order for activation:
#   1. Ticketmaster + SeatGeek  (free API keys, add immediately — unlocks priced events)
#   2. Netlify                  (free, deploys the landing page publicly)
#   3. Telegram                 (free bot, highest-ROI distribution channel)
#   4. Google Sheets            (data logging + pricing history)
#   5. Twitter / Reddit         (free dev accounts, expands reach)
#   6. Affiliate IDs            (passive revenue on every click-through)
#   7. Stripe                   (enables integrated booking checkout — big revenue unlock)
# ============================================================


# ── Event APIs (free tier, get these first) ───────────────────────────────────

# Ticketmaster Discovery API — concerts, sports, theater — ALWAYS has prices
# Sign up free at: developer.ticketmaster.com
# 5,000 API calls/day free
TICKETMASTER_API_KEY=

# SeatGeek — concerts, sports, comedy — ALWAYS has prices
# Sign up free at: platform.seatgeek.com
SEATGEEK_CLIENT_ID=


# ── Landing Page (Netlify — free tier) ───────────────────────────────────────

# Run: python tools/setup_landing_page.py  to auto-create site and write these
# Or: netlify.com -> Sites -> your site -> Site settings -> API ID
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=

# Auto-populated by setup_landing_page.py (your live URL)
LANDING_PAGE_URL=


# ── Telegram Distribution (free — highest open rate) ─────────────────────────

# 1. Message @BotFather on Telegram -> /newbot
# 2. Copy the token it gives you
# 3. Create a public channel (e.g. @lastminutedeals_us)
# 4. Add the bot as admin to the channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@lastminutedeals_us


# ── Google Sheets (data store + pricing log) ──────────────────────────────────

# Run: python tools/setup_google_sheets.py  to create the sheet and write this
# Or: open your sheet -> copy the ID from the URL (between /d/ and /edit)
GOOGLE_SHEET_ID=


# ── Twitter / X Distribution ──────────────────────────────────────────────────

# Sign up at: developer.twitter.com -> New Project -> App -> OAuth 1.0a -> read+write
# Generate Access Token + Secret for your account
# Free tier: 1,500 tweets/month (50/day)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=


# ── Reddit Distribution ───────────────────────────────────────────────────────

# 1. Create a Reddit account for the bot
# 2. Go to: reddit.com/prefs/apps -> "create another app" -> Script
# 3. Fill in name, description, redirect uri = http://localhost:8080
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=LastMinuteDealsBot/1.0 by u/YOUR_USERNAME


# ── Affiliate Programs (passive revenue on every click-through) ───────────────

# Eventbrite affiliate — join at: eventbrite.com/affiliate (via Impact)
EVENTBRITE_AFFILIATE_ID=

# Ticketmaster affiliate — join at: partners.ticketmaster.com (via CJ Affiliate)
TICKETMASTER_AFFILIATE_ID=

# SeatGeek affiliate — contact SeatGeek partner portal
SEATGEEK_AFFILIATE_ID=

# Booking.com affiliate — join at: join.booking.com (Affiliate Partner Program)
# Commission: ~4% of booking value
BOOKING_COM_AFFILIATE_ID=

# Expedia affiliate — join at: expediagroup.com/partners (Expedia Partner Solutions)
EXPEDIA_AFFILIATE_ID=

# TripAdvisor affiliate — join at: tripadvisor.com/affiliates
TRIPADVISOR_AFFILIATE_ID=

# Booksy affiliate — contact Booksy partnerships team
BOOKSY_AFFILIATE_CODE=


# ── Stripe (integrated booking checkout — revenue unlock) ─────────────────────

# Sign up at: stripe.com -> Developers -> API Keys
# Use TEST keys during development; switch to LIVE when ready
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL where run_api_server.py is running (set after deploying to Railway/Render/Fly.io)
# For local testing: http://localhost:5050/api/book
# For production: https://your-server.railway.app/api/book
BOOKING_API_URL=


# ── Cloudflare Pages (alternative to Netlify, unlimited updates) ───────────────

# Create account at: cloudflare.com -> Pages -> Create project -> Direct Upload
# Get API token at: dash.cloudflare.com/profile/api-tokens -> Create Token
# Token needs: Cloudflare Pages:Edit permission
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=lastminutedeals


# ── OCTO-Compliant Booking Platforms (activities/experiences/tours) ───────────
#
# These are the supply-side APIs. Each unlocks hundreds of bookable experiences.
# The pipe: fetch_octo_slots.py + fetch_rezdy_slots.py → MCP server → book_slot
#
# ── Ventrata (FASTEST — test sandbox, no signup needed) ───────────────────────
# Get test API key: https://docs.ventrata.com/getting-started/getting-started
# Test against EdinExplore supplier immediately. Production approval: 1-2 days.
# Email: connectivity@ventrata.com after testing.
VENTRATA_API_KEY=

# ── Rezdy Agent API (FREE account, API key in 48h) ────────────────────────────
# 1. Sign up free at rezdy.com (select "Reseller" during signup)
# 2. Go to Integrations menu → Request API Key (approved in ~48 hours)
# 3. Test in staging first: python tools/fetch_rezdy_slots.py --staging
REZDY_API_KEY=

# ── Bokun ($49/month START plan, self-serve) ──────────────────────────────────
# 1. Sign up at bokun.io, select Reseller role
# 2. Generate API key: Settings > Connections > API Keys
# 3. Email support@bokun.io for demo environment credentials
# 1.5% booking fee applies to all Bokun API bookings
BOKUN_API_KEY=

# ── Xola (free sandbox, email kick-off call for production) ───────────────────
# 1. Register at developers.xola.com
# 2. Create Distribution Channel app in App Store Console (sandbox immediate)
# 3. Email Xola to schedule kick-off call for production access
XOLA_API_KEY=

# ── Peek Pro (email ben.smithart@peek.com to request access) ──────────────────
PEEK_API_KEY=

# ── FareHarbor (affiliate tier accessible; API tier needs $250k TTM) ──────────
# Affiliate: email channelsupport@fareharbor.com with company info
# API: requires $250k trailing 12-month transaction volume on affiliate dashboard
FAREHARBOR_API_KEY=


# ── Mindbody Agency Account (wellness/fitness booking fulfillment) ─────────────
#
# Used by MindbodyBooker to execute reservations on behalf of customers.
# The agency account books via "Reserve for Someone Else" — no customer account needed.
# See: workflows/octo_integration.md for setup steps.
#
# Create a Mindbody account at a yopmail address (yopmail.com).
# Add a business card/payment method to the account.
MINDBODY_AGENCY_EMAIL=
MINDBODY_AGENCY_PASSWORD=

# Card details (optional — used if no pre-purchased credits on agency account)
MINDBODY_AGENCY_CARD_NUMBER=
MINDBODY_AGENCY_CARD_EXP=
MINDBODY_AGENCY_CARD_CVV=


# ── SMS Alerts via Twilio (optional — highest conversion channel) ──────────────

# Sign up at: twilio.com -> Console -> Account Info
# ~$0.0079 per SMS (US)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...
