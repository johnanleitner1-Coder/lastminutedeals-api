# ============================================================
# .env.example — Copy this to .env and fill in your values.
# Never commit .env to git.
# ============================================================
# Priority order for activation:
#   1. Bokun API key     (core supply — OCTO booking pipeline)
#   2. Stripe            (enables integrated booking checkout — revenue)
#   3. Netlify/Cloudflare (deploys the landing page publicly)
#   4. Supabase          (persistent slot + booking storage)
#   5. Telegram          (free bot, highest-ROI distribution channel)
#   6. Google Sheets     (data logging + pricing history)
#   7. Twitter / Reddit  (free dev accounts, expands reach)
#   8. Affiliate IDs     (passive revenue on click-throughs)
# ============================================================


# ── OCTO-Compliant Booking Platforms (core supply) ───────────────────────────
#
# These are the supply-side APIs. Each unlocks hundreds of bookable experiences.
# The pipe: fetch_octo_slots.py + fetch_rezdy_slots.py -> MCP server -> book_slot

# ── Bokun ($49/month START plan, self-serve) ──────────────────────────────────
# 1. Sign up at bokun.io, select Reseller role
# 2. Generate API key: Settings > Connections > API Keys
# 1.5% booking fee applies to all Bokun API bookings
BOKUN_API_KEY=

# ── Ventrata (FASTEST — test sandbox, no signup needed) ───────────────────────
# Get test API key: https://docs.ventrata.com/getting-started/getting-started
# Production approval: 1-2 days. Email: connectivity@ventrata.com
VENTRATA_API_KEY=

# ── Rezdy Agent API (FREE account, API key in 48h) ────────────────────────────
# Email partnerintegrations@rezdy.com to request reseller API access
REZDY_API_KEY=

# ── Xola (free sandbox, email kick-off call for production) ───────────────────
XOLA_API_KEY=

# ── Peek Pro (email ben.smithart@peek.com to request access) ──────────────────
PEEK_API_KEY=


# ── Stripe (integrated booking checkout — revenue) ──────────────────────────

# Sign up at: stripe.com -> Developers -> API Keys
# Use TEST keys during development; switch to LIVE when ready
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL where run_api_server.py is running (set after deploying to Railway/Render/Fly.io)
BOOKING_API_URL=


# ── Landing Page (Netlify — free tier) ───────────────────────────────────────

NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
LANDING_PAGE_URL=


# ── Cloudflare Pages (alternative to Netlify) ───────────────────────────────

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=lastminutedeals


# ── Supabase (persistent storage for slots, bookings, wallets) ───────────────

SUPABASE_URL=
SUPABASE_SECRET_KEY=


# ── Google Sheets (data store + pricing log) ──────────────────────────────────

GOOGLE_SHEET_ID=


# ── Telegram Distribution (free — highest open rate) ─────────────────────────

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@lastminutedeals_us


# ── Twitter / X Distribution ──────────────────────────────────────────────────

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=


# ── Reddit Distribution ───────────────────────────────────────────────────────

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=LastMinuteDealsBot/1.0 by u/YOUR_USERNAME


# ── Affiliate Programs (passive revenue on click-throughs) ───────────────────

# Booking.com affiliate — join at: join.booking.com
BOOKING_COM_AFFILIATE_ID=

# Expedia affiliate — join at: expediagroup.com/partners
EXPEDIA_AFFILIATE_ID=

# TripAdvisor affiliate — join at: tripadvisor.com/affiliates
TRIPADVISOR_AFFILIATE_ID=


# ── SMS Alerts via Twilio (optional — highest conversion channel) ──────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...


# ── SendGrid (booking confirmation emails) ───────────────────────────────────

SENDGRID_API_KEY=
